{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Civ2 Disagreement Object",
  "type": "object",
  "required": ["id","title","stable_scope","positions","status","created_utc","last_updated_utc"],
  "properties": {
    "id": { "type": "string", "pattern": "^C2\\\\.DIS\\\\.DL-[0-9]{4}(\\\\.[A-Z0-9_-]+)?$" },
    "title": { "type": "string" },
    "stable_scope": { "type": "string", "description": "Which Civ2 stable IDs this disagreement touches." },
    "positions": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name","steelman","claims","risks","tests"],
        "properties": {
          "name": { "type": "string" },
          "steelman": { "type": "string" },
          "claims": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } },
          "tests": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "status": { "type": "string", "enum": ["open","narrowing","conditional","resolved","forked"] },
    "created_utc": { "type": "string" },
    "last_updated_utc": { "type": "string" },
    "receipts": { "type": "array", "items": { "type": "string" } }
  }
}